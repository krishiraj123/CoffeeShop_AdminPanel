@using System.Data;

<main id="main" class="main">
    <div class="pagetitle">
        <h1>Project List</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="breadcrumb-item">Tables</li>
                <li class="breadcrumb-item active">Data</li>
            </ol>
        </nav>
    </div>
    <div>
        <table class="table datatable table table-striped table-bordered table-hover table-responsive">
            <thead>
            <tr>
                <th>ProjectID</th>
                <th>ProjectName</th>
                <th>Description</th>
                <th>Status</th>
                <th>Budget</th>
                <th>CreatedDate</th>
                <th>LastUpdated</th>
                <th>Operation</th>
            </tr>
            </thead>
            <tbody>
            @foreach (DataRow dr in Model.Rows)
            {
                <tr>
                    <td>@dr["ProjectID"]</td>
                    <td>@dr["ProjectName"]</td>
                    <td>@dr["Description"]</td>
                    <td>@dr["Status"]</td>
                    <td>@dr["Budget"]</td>
                    <td>@dr["CreatedDate"]</td>
                    <td>@dr["LastUpdated"]</td>
                    <td>
                        <div class="d-flex align-items-center">
                            <button type="button" class="btn btn-link p-0 mx-3" title="Delete" onclick="confirmDelete('@dr["ProjectID"]')">
                                <i class="fas fa-trash text-danger"></i>
                            </button>
                            <a asp-controller="Project" asp-action="ProjectAddEdit" asp-route-UserID="@dr["ProjectID"]" class="btn btn-link p-0" title="Edit">
                                <i class="fas fa-edit text-warning"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</main>
<script>
    const confirmDelete = (ProjectID)=>{
        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!'
        }).then((res)=>{
            if(res.isConfirmed){
                window.location.href = @Url.Action("ProjectDelete","Project") + "?ProjectID="+ProjectID;
            }
        })
    }
</script>